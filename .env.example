# Copy this file to .env and fill in local secrets.
# Never commit .env.

# DeepSeek exposes an OpenAI-compatible endpoint.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com

# Model roles used by the diagnostic harness.
INCIDENT_PRIMARY_MODEL=deepseek-v4-pro
INCIDENT_FALLBACK_MODEL=deepseek-v4-flash
INCIDENT_SUPERVISOR_MODEL=deepseek-v4-flash
INCIDENT_REPORT_MODEL=deepseek-v4-pro
# Free local embedding recommendation for Chinese-first retrieval.
# Requires optional dependency: fastembed
INCIDENT_EMBEDDING_PROVIDER=fastembed
INCIDENT_RAG_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
INCIDENT_MEMORY_PROVIDER=bm25

# Runtime tuning.
INCIDENT_LLM_TEMPERATURE=0
INCIDENT_DEEPSEEK_THINKING=disabled
INCIDENT_ENABLE_LLM_ROUTING=false
INCIDENT_ENABLE_LLM_REPORT=false
